{
  "name": "tickytocky",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "asset:watch": "sh tools/blender/build-watch-model.sh",
    "build": "tsc -b && vite build",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test:unit && pnpm build",
    "dev": "vite",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint .",
    "preview": "vite preview",
    "test": "pnpm test:unit && pnpm test:e2e",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:unit": "vitest run src --passWithNoTests",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@react-three/drei": "10.7.7",
    "@react-three/fiber": "9.6.1",
    "animejs": "4.5.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "three": "0.185.1"
  },
  "devDependencies": {
    "@gltf-transform/cli": "4.4.1",
    "@playwright/test": "1.61.1",
    "@tailwindcss/vite": "4.3.2",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/three": "0.185.1",
    "@vitejs/plugin-react": "6.0.3",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "oxlint-tsgolint": "0.24.0",
    "tailwindcss": "4.3.2",
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  },
  "engines": {
    "node": ">=24.0.0 <25"
  },
  "packageManager": "pnpm@11.13.1"
}
